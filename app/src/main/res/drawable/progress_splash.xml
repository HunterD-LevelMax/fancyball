<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape>
            <corners android:radius="100dp" />
            <solid android:color="@color/fb_surface_alt" />
            <stroke
                android:width="1dp"
                android:color="@color/fb_white_14" />
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <clip>
            <shape>
                <corners android:radius="100dp" />
                <gradient
                    android:angle="0"
                    android:startColor="@color/fb_cyan"
                    android:centerColor="@color/fb_gold"
                    android:endColor="@color/fb_pink" />
            </shape>
        </clip>
    </item>
</layer-list>
